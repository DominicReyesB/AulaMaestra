<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.Aula.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="strokeWidth">0dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="Widget.Aula.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">@dimen/card_radius_sm</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Aula.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.Aula.Button.Secondary" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@color/secondary_container</item>
        <item name="android:textColor">@color/on_secondary_container</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Aula.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Aula.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Aula.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/outline</item>
        <item name="hintTextColor">@color/on_surface_variant</item>
    </style>

    <style name="Widget.Aula.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/primary</item>
        <item name="titleTextColor">@color/on_primary</item>
        <item name="subtitleTextColor">@color/primary_container</item>
        <item name="navigationIconTint">@color/on_primary</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="Widget.Aula.Tab" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/secondary</item>
        <item name="tabSelectedTextColor">@color/primary</item>
        <item name="tabTextColor">@color/on_surface_variant</item>
        <item name="tabRippleColor">@color/primary_container</item>
    </style>

    <style name="Widget.Aula.Fab" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/secondary</item>
        <item name="tint">@color/on_primary</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="Text.Aula.Display" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Text.Aula.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Text.Aula.Subtitle" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <style name="Text.Aula.Section" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Text.Aula.Chip" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="Text.Aula.Empty" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:gravity">center</item>
    </style>
</resources>
