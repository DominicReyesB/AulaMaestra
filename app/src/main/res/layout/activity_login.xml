<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="@dimen/space_lg"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_launcher_legacy" />

        <TextView
            style="@style/Text.Aula.Display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="@string/app_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_lg"
            android:gravity="center"
            android:text="@string/login_tagline"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/on_surface_variant" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Aula.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/roleToggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:checkedButton="@+id/btnTeacher"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTeacher"
                        style="@style/Widget.Aula.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/role_teacher" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStudent"
                        style="@style/Widget.Aula.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/role_student" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!-- Maestra -->
                <LinearLayout
                    android:id="@+id/teacherBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Aula.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:hint="@string/username">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputUser"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Aula.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:hint="@string/password"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputPass"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLoginTeacher"
                        style="@style/Widget.Aula.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/login" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegisterTeacher"
                        style="@style/Widget.Aula.Button.Text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/register_teacher_hint" />
                </LinearLayout>

                <!-- Alumno: un solo formulario -->
                <LinearLayout
                    android:id="@+id/studentBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/textStudentWelcome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:background="@drawable/bg_chip_assignment"
                        android:gravity="center"
                        android:padding="@dimen/space_sm"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="@color/chip_assignment_text"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/student_simple_hint"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/on_surface_variant" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Aula.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:hint="@string/student_code">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputStudentCode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapCharacters" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Aula.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:hint="@string/student_name">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputStudentName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEnterStudent"
                        style="@style/Widget.Aula.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/student_login" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegisterStudent"
                        style="@style/Widget.Aula.Button.Secondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/student_register" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSwitchStudent"
                        style="@style/Widget.Aula.Button.Text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/student_switch"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
