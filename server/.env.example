# Railway MySQL: enlaza el servicio MySQL y usa MYSQL_URL (recomendado)
MYSQL_URL=mysql://usuario:password@host.railway.app:3306/railway

# O variables sueltas que Railway inyecta al enlazar MySQL:
# MYSQLHOST=...
# MYSQLUSER=...
# MYSQLPASSWORD=...
# MYSQLDATABASE=railway
# MYSQLPORT=3306

PORT=3000
PUBLIC_URL=https://tu-api.up.railway.app

# Opcional: activa el chatbot de Ayuda. Nunca pongas esta clave en la app Android.
OPENAI_API_KEY=
OPENAI_HELP_MODEL=gpt-4o-mini
